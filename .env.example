# miniloop — primary interface is the MCP server (no API key needed)
# See README.md for setup instructions.

# ── Optional: standalone CLI mode (requires an LLM backend) ──────────────────
# Only needed if you want to run: python -m miniloop "goal" --autonomy auto
# The MCP server (miniloop.mcp_server) does NOT use these variables.

# Bob API
# API_BASE_URL=https://api.us-east.bob.ibm.com/inference/v1
# API_KEY=<your-bob-inference-key>
# API_AUTH_SCHEME=apikey
# MINILOOP_MODEL=<model-id>

# Anthropic
# API_BASE_URL=https://api.anthropic.com/v1
# API_KEY=sk-ant-...
# API_AUTH_SCHEME=Bearer
# MINILOOP_MODEL=claude-3-5-haiku-20241022

# Ollama (local)
# API_BASE_URL=http://localhost:11434/v1
# API_KEY=ollama
# API_AUTH_SCHEME=Bearer
# MINILOOP_MODEL=qwen2.5-coder:14b
