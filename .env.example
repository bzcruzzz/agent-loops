# miniloop — bring your own LLM (any OpenAI-compatible endpoint)
# Priority: if LITELLM_API_KEY is set, litellm proxy is used; otherwise API_KEY path.

# ── Option 1: IBM LiteLLM proxy (IBM network / VPN required) ─────────────────
LITELLM_API_KEY=sk-6vSzPoi24PyJA6UjGWfiUg
LITELLM_BASE_URL=https://pgx.blum.coffee/v1
LITELLM_MODEL=openai/chat

# ── Option 2: Bob API ─────────────────────────────────────────────────────────
# API_BASE_URL=https://api.us-east.bob.ibm.com/inference/v1
# API_KEY=<your-bob-inference-key>
# API_AUTH_SCHEME=apikey
# MINILOOP_MODEL=claude-sonnet-4-5

# ── Option 3: Anthropic direct ────────────────────────────────────────────────
# API_BASE_URL=https://api.anthropic.com/v1
# API_KEY=sk-ant-...
# API_AUTH_SCHEME=Bearer
# MINILOOP_MODEL=claude-3-5-haiku-20241022

# ── Option 4: OpenAI ──────────────────────────────────────────────────────────
# API_BASE_URL=https://api.openai.com/v1
# API_KEY=sk-...
# API_AUTH_SCHEME=Bearer
# MINILOOP_MODEL=gpt-4o-mini

# ── Option 5: Ollama (local, no key needed) ───────────────────────────────────
# API_BASE_URL=http://localhost:11434/v1
# API_KEY=ollama
# API_AUTH_SCHEME=Bearer
# MINILOOP_MODEL=llama3.1
